#!/usr/bin/env bash
set -euo pipefail

APP_NAME="hiddenAI"

# =========================
# Resolve real script path (symlink safe)
# =========================
SOURCE="${BASH_SOURCE[0]}"

while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done

BASE_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# =========================
# Paths
# =========================
INFO_DIR="$BASE_DIR/info"
PID_FILE="$INFO_DIR/.hiddenAI.pid"
LOG_FILE="$INFO_DIR/hiddenAI.log"

VENV="$BASE_DIR/venv/bin/activate"
SCRIPT="$BASE_DIR/main.py"

# =========================
# Colors
# =========================
GREEN="\033[1;32m"
RED="\033[1;31m"
YELLOW="\033[1;33m"
BLUE="\033[1;34m"
RESET="\033[0m"

log() {
    echo -e "${BLUE}[$APP_NAME]${RESET} $1"
}

success() {
    echo -e "${GREEN}[$APP_NAME] $1${RESET}"
}

error() {
    echo -e "${RED}[$APP_NAME] ERROR: $1${RESET}"
}

warn() {
    echo -e "${YELLOW}[$APP_NAME] $1${RESET}"
}

# =========================
# Ensure folders exist
# =========================
prepare_env () {
    mkdir -p "$INFO_DIR"

    if [ ! -f "$SCRIPT" ]; then
        error "main.py not found at $SCRIPT"
        exit 1
    fi

    if [ ! -f "$VENV" ]; then
        error "Virtual environment not found."
        warn "Create it with:"
        echo "python3 -m venv venv"
        echo "source venv/bin/activate"
        echo "pip install -r requirements.txt"
        exit 1
    fi
}

# =========================
# Check if running
# =========================
is_running () {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")

        if ps -p "$PID" > /dev/null 2>&1; then
            return 0
        else
            warn "Stale PID file found. Cleaning..."
            rm -f "$PID_FILE"
            return 1
        fi
    fi
    return 1
}

# =========================
# START
# =========================
start_app () {

    prepare_env

    if is_running; then
        warn "Already running (PID $(cat "$PID_FILE"))"
        exit 0
    fi

    log "Starting HiddenAI..."

    source "$VENV"

    nohup python3 "$SCRIPT" \
        >> "$LOG_FILE" 2>&1 &

    PID=$!
    echo "$PID" > "$PID_FILE"

    sleep 1

    if ps -p "$PID" > /dev/null 2>&1; then
        success "Started successfully (PID $PID)"
        log "Logs → $LOG_FILE"
    else
        error "Failed to start"
        echo "------ DEBUG LOG ------"
        cat "$LOG_FILE"
        echo "-----------------------"
        exit 1
    fi
}

# =========================
# STOP
# =========================
stop_app () {

    if is_running; then
        PID=$(cat "$PID_FILE")
        log "Stopping process $PID"

        kill "$PID"

        sleep 1

        if ps -p "$PID" > /dev/null 2>&1; then
            warn "Force killing..."
            kill -9 "$PID"
        fi

        rm -f "$PID_FILE"

        success "Stopped"
    else
        warn "Not running"
    fi
}

# =========================
# STATUS
# =========================
status_app () {

    if is_running; then
        success "Running (PID $(cat "$PID_FILE"))"
    else
        warn "Stopped"
    fi
}

# =========================
# LOGS
# =========================
logs_app () {

    if [ -f "$LOG_FILE" ]; then
        log "Streaming logs..."
        tail -f "$LOG_FILE"
    else
        warn "No logs yet"
    fi
}

# =========================
# RESTART
# =========================
restart_app () {
    stop_app
    start_app
}

# =========================
# CLI
# =========================
case "${1:-}" in
    start)
        start_app
        ;;
    stop)
        stop_app
        ;;
    restart)
        restart_app
        ;;
    status)
        status_app
        ;;
    logs)
        logs_app
        ;;
    *)
        echo "Usage:"
        echo "  hiddenAI start"
        echo "  hiddenAI stop"
        echo "  hiddenAI restart"
        echo "  hiddenAI status"
        echo "  hiddenAI logs"
        exit 1
        ;;
esac