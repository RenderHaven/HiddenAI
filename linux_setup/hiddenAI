#!/usr/bin/env bash
set -e

APP_NAME="hiddenAI"

# =========================
# Resolve real script path (symlink safe)
# =========================
SOURCE="${BASH_SOURCE[0]}"

while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done

BASE_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# =========================
# Paths
# =========================
VENV="$BASE_DIR/venv/bin/activate"
SCRIPT="$BASE_DIR/main.py"
PID_FILE="$BASE_DIR/info/.hiddenAI.pid"
LOG_FILE="$BASE_DIR/info/hiddenAI.log"

# =========================
# START
# =========================
start_app () {

    echo "[hiddenAI] Starting..."
    echo "[hiddenAI] BASE_DIR = $BASE_DIR"
    echo "[hiddenAI] Venv = $VENV"

    if [ ! -f "$VENV" ]; then
        echo "[hiddenAI] ERROR: venv activate not found at $VENV"
        exit 1
    fi

    if [ ! -f "$SCRIPT" ]; then
        echo "[hiddenAI] ERROR: main.py not found"
        exit 1
    fi
    if [ ! -d "info" ]; then
        mkdir info
    fi
    # stop old instance
    stop_app 2>/dev/null || true

    echo "[hiddenAI] Activating venv..."
    source "$VENV"

    echo "[hiddenAI] Launching process..."

    # ⭐ run inside SAME shell so venv stays active
    nohup python3 "$SCRIPT" \
        > "$LOG_FILE" 2>&1 &

    PID=$!
    echo $PID > "$PID_FILE"

    sleep 1

    if ps -p "$PID" > /dev/null 2>&1; then
        echo "[hiddenAI] Started successfully (PID $PID)"
        echo "[hiddenAI] Logs → $LOG_FILE"
    else
        echo "[hiddenAI] FAILED TO START"
        echo "------ DEBUG LOG ------"
        cat "$LOG_FILE"
        echo "-----------------------"
        exit 1
    fi
}

# =========================
# STOP
# =========================
stop_app () {

    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")

        if ps -p "$PID" > /dev/null 2>&1; then
            echo "[hiddenAI] Stopping PID $PID"
            kill "$PID"
        else
            echo "[hiddenAI] Process not running"
        fi

        rm -f "$PID_FILE"
    else
        echo "[hiddenAI] No PID file found"
    fi
}

# =========================
# STATUS
# =========================
status_app () {

    if [ -f "$PID_FILE" ] && ps -p "$(cat "$PID_FILE")" > /dev/null 2>&1; then
        echo "[hiddenAI] Running (PID $(cat "$PID_FILE"))"
    else
        echo "[hiddenAI] Stopped"
    fi
}

# =========================
# LOGS
# =========================
logs_app () {
    if [ -f "$LOG_FILE" ]; then
        tail -f "$LOG_FILE"
    else
        echo "[hiddenAI] No logs yet"
    fi
}

# =========================
# CLI
# =========================
case "$1" in
    start)
        start_app
        ;;
    stop)
        stop_app
        ;;
    restart)
        stop_app
        start_app
        ;;
    status)
        status_app
        ;;
    logs)
        logs_app
        ;;
    *)
        echo "Usage: hiddenAI {start|stop|restart|status|logs}"
        ;;
esac